# Blocklog Frontend — Environment Configuration
# Copy this file to .env.local and fill in values.
# NEVER commit .env.local to version control.

# Backend API URL
# Local development: http://localhost:8000/api/v1
# Self-hosted production: https://your-backend-domain.com/api/v1
NEXT_PUBLIC_BLOCKLOG_API_BASE_URL=http://localhost:8000/api/v1